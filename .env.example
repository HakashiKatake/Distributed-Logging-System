# PostgreSQL configurations
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=logging_db

# OpenSearch configurations
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=AdminPassword123!

# Kafka configurations
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_TOPIC=distributed-logs

# MinIO / S3 configurations
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cold-logs-archive

# Alertmanager configuration
ALERTMANAGER_URL=http://localhost:9093/api/v2/alerts

# Ingestion configuration
INGESTION_PORT=8000
SEARCH_PORT=8000

# Retention policies (in minutes for easy local demo validation)
HOT_RETENTION_MINUTES=5
COLD_RETENTION_MINUTES=15
